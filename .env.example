# Custom Webmail Panel - Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Admin panel port
PORT=3001

# Database connection
DB_HOST=localhost
DB_NAME=mailserver
DB_USER=mailuser
DB_PASS=your_database_password_here

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=generate_random_64_char_hex_here

# JWT secret for API authentication (generate with: openssl rand -hex 32)
JWT_SECRET=generate_random_64_char_hex_here

# Mail server hostname
HOSTNAME=mail.yourdomain.com

# Environment
NODE_ENV=production

# Default password used for auto-login feature
DEFAULT_MAIL_PASS=change_this_default_password
