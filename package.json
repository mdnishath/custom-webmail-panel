{
  "name": "custom-webmail-panel",
  "version": "1.0.0",
  "description": "Self-hosted mail server admin panel with multi-session webmail support. Manage multiple domains, email accounts, aliases, DKIM, and DNS records. Features simultaneous webmail logins in the same browser via path-based cookie isolation.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js"
  },
  "keywords": [
    "mail-server",
    "webmail",
    "admin-panel",
    "postfix",
    "dovecot",
    "roundcube",
    "email",
    "multi-domain",
    "dkim",
    "self-hosted",
    "multi-session"
  ],
  "author": "mdnishath",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mdnishath/custom-webmail-panel.git"
  },
  "bugs": {
    "url": "https://github.com/mdnishath/custom-webmail-panel/issues"
  },
  "homepage": "https://github.com/mdnishath/custom-webmail-panel#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.5"
  }
}
