<%- include('header') %>
<div class="top-bar">
  <div>
    <h4 class="mb-0 fw-bold"><i class="bi bi-box-arrow-in-right"></i> Auto Login</h4>
    <small class="text-muted">Login to webmail as <%= email %></small>
  </div>
  <a href="/emails" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
</div>
<div class="card" style="max-width:500px">
  <div class="card-body">
    <form method="POST" action="/autologin/login/<%= userId %>">
      <div class="mb-3">
        <label class="form-label fw-bold">Email</label>
        <input type="text" class="form-control" value="<%= email %>" readonly>
      </div>
      <div class="mb-3">
        <label class="form-label fw-bold">Password</label>
        <input type="password" name="password" class="form-control" value="CHANGE_ME" required>
      </div>
      <button type="submit" class="btn btn-primary w-100"><i class="bi bi-box-arrow-in-right"></i> Login to Webmail</button>
    </form>
  </div>
</div>
<%- include('footer') %>
