<%- include('header') %>

<div class="top-bar">
  <div>
    <h4 class="mb-0 fw-bold">
      <span style="color:<%= group.color %>"><i class="bi bi-circle-fill" style="font-size:0.7rem"></i></span>
      <%= group.name %>
    </h4>
    <small class="text-muted"><%= group.description || 'No description' %> | <%= members.length %> members</small>
  </div>
  <div>
    <button class="btn btn-outline-info me-2" onclick="copyAllEmails()" title="Copy all emails"><i class="bi bi-clipboard"></i> Copy All Emails</button>
    <button class="btn btn-success me-2" data-bs-toggle="modal" data-bs-target="#addMemberModal"><i class="bi bi-person-plus"></i> Add Members</button>
    <a href="/groups" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
  </div>
</div>

<% if (error) { %><div class="alert alert-danger alert-dismissible fade show"><%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
<% if (success) { %><div class="alert alert-success alert-dismissible fade show"><%= success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>

<!-- Toast -->
<div class="position-fixed top-0 end-0 p-3" style="z-index:9999">
  <div id="copyToast" class="toast align-items-center text-bg-success" role="alert">
    <div class="d-flex">
      <div class="toast-body" id="toastMsg"><i class="bi bi-check-circle"></i> Copied!</div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
    </div>
  </div>
</div>

<!-- Members Table -->
<div class="card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <span><i class="bi bi-people"></i> Group Members</span>
    <input type="text" id="searchMembers" class="form-control form-control-sm" style="width:200px" placeholder="Search members..." oninput="filterMembers()">
  </div>
  <div class="card-body p-0">
    <table class="table table-hover">
      <thead>
        <tr><th>#</th><th>Email</th><th>Name</th><th>Domain</th><th>Actions</th></tr>
      </thead>
      <tbody>
        <% if (members.length === 0) { %>
          <tr><td colspan="5" class="text-center text-muted py-5">No members in this group. Click "Add Members" to start.</td></tr>
        <% } %>
        <% members.forEach(function(m, index) { %>
          <tr class="member-row" data-email="<%= m.email.toLowerCase() %>" data-name="<%= (m.full_name || '').toLowerCase() %>">
            <td class="text-muted fw-bold"><%= index + 1 %></td>
            <td>
              <strong style="cursor:pointer;border-bottom:1px dashed #4e73df;color:#4e73df" onclick="copyEmail('<%= m.email %>')" title="Click to copy"><%= m.email %></strong>
            </td>
            <td><%= m.full_name || '-' %></td>
            <td><%= m.domain_name %></td>
            <td>
              <button class="btn btn-sm btn-primary me-1" onclick="window.open('https://webmail.YOUR_DOMAIN/?_user='+encodeURIComponent('<%= m.email %>'),'wm_<%= m.id %>')" title="Webmail"><i class="bi bi-box-arrow-up-right"></i></button>
              <form method="POST" action="/groups/<%= group.id %>/remove-member/<%= m.membership_id %>" class="d-inline">
                <button class="btn btn-sm btn-outline-danger" title="Remove from group"><i class="bi bi-person-dash"></i></button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<!-- Add Members Modal -->
<div class="modal fade" id="addMemberModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <form method="POST" action="/groups/<%= group.id %>/add-members">
        <div class="modal-header">
          <h5 class="modal-title"><i class="bi bi-person-plus"></i> Add Members to <%= group.name %></h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <input type="text" id="searchAvailable" class="form-control" placeholder="Search available accounts..." oninput="filterAvailable()">
          </div>
          <div class="mb-2 d-flex gap-2">
            <button type="button" class="btn btn-sm btn-outline-primary" onclick="selectAll()">Select All</button>
            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="deselectAll()">Deselect All</button>
            <span class="text-muted ms-auto" id="selectedCount">0 selected</span>
          </div>
          <div style="max-height:400px;overflow-y:auto;border:1px solid #dee2e6;border-radius:8px">
            <% if (allUsers.length === 0) { %>
              <p class="text-center text-muted py-4">All accounts are already in this group.</p>
            <% } %>
            <% allUsers.forEach(function(u) { %>
              <label class="available-user d-flex align-items-center px-3 py-2 border-bottom" style="cursor:pointer" data-email="<%= u.email.toLowerCase() %>" data-name="<%= (u.full_name || '').toLowerCase() %>">
                <input type="checkbox" name="user_ids" value="<%= u.id %>" class="form-check-input me-3 user-checkbox" onchange="updateCount()">
                <div>
                  <strong><%= u.email %></strong>
                  <small class="text-muted d-block"><%= u.full_name || '' %> | <%= u.domain_name %></small>
                </div>
              </label>
            <% }); %>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-success"><i class="bi bi-person-plus"></i> Add Selected</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
function copyEmail(email) {
  navigator.clipboard.writeText(email).then(function() {
    document.getElementById('toastMsg').innerHTML = '<i class="bi bi-check-circle"></i> ' + email + ' copied!';
    var t = new bootstrap.Toast(document.getElementById('copyToast'), {delay: 1500});
    t.show();
  });
}

function copyAllEmails() {
  var emails = [];
  document.querySelectorAll('.member-row').forEach(function(r) {
    emails.push(r.getAttribute('data-email'));
  });
  navigator.clipboard.writeText(emails.join(', ')).then(function() {
    document.getElementById('toastMsg').innerHTML = '<i class="bi bi-check-circle"></i> ' + emails.length + ' emails copied!';
    var t = new bootstrap.Toast(document.getElementById('copyToast'), {delay: 2000});
    t.show();
  });
}

function filterMembers() {
  var q = document.getElementById('searchMembers').value.toLowerCase();
  document.querySelectorAll('.member-row').forEach(function(r) {
    var show = r.getAttribute('data-email').includes(q) || r.getAttribute('data-name').includes(q);
    r.style.display = show ? '' : 'none';
  });
}

function filterAvailable() {
  var q = document.getElementById('searchAvailable').value.toLowerCase();
  document.querySelectorAll('.available-user').forEach(function(r) {
    var show = r.getAttribute('data-email').includes(q) || r.getAttribute('data-name').includes(q);
    r.style.display = show ? '' : 'none';
  });
}

function selectAll() {
  document.querySelectorAll('.available-user').forEach(function(r) {
    if (r.style.display !== 'none') {
      r.querySelector('.user-checkbox').checked = true;
    }
  });
  updateCount();
}

function deselectAll() {
  document.querySelectorAll('.user-checkbox').forEach(function(c) { c.checked = false; });
  updateCount();
}

function updateCount() {
  var count = document.querySelectorAll('.user-checkbox:checked').length;
  document.getElementById('selectedCount').textContent = count + ' selected';
}
</script>

<%- include('footer') %>
