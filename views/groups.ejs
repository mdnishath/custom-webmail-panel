<%- include('header') %>

<div class="top-bar">
  <div>
    <h4 class="mb-0 fw-bold"><i class="bi bi-people"></i> Email Groups</h4>
    <small class="text-muted">Organize email accounts into groups</small>
  </div>
  <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addGroupModal">
    <i class="bi bi-plus-circle"></i> Create Group
  </button>
</div>

<% if (error) { %><div class="alert alert-danger alert-dismissible fade show"><%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
<% if (success) { %><div class="alert alert-success alert-dismissible fade show"><%= success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>

<div class="row g-4">
  <% if (groups.length === 0) { %>
    <div class="col-12">
      <div class="card">
        <div class="card-body text-center text-muted py-5">
          <i class="bi bi-people" style="font-size:3rem"></i>
          <p class="mt-2">No groups yet. Create a group to organize your email accounts.</p>
        </div>
      </div>
    </div>
  <% } %>
  <% groups.forEach(function(g) { %>
    <div class="col-md-4">
      <div class="card" style="border-left: 4px solid <%= g.color %>">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <h5 class="fw-bold mb-1">
                <span style="color:<%= g.color %>"><i class="bi bi-circle-fill" style="font-size:0.6rem"></i></span>
                <%= g.name %>
              </h5>
              <p class="text-muted small mb-2"><%= g.description || 'No description' %></p>
            </div>
            <form method="POST" action="/groups/<%= g.id %>/delete" class="d-inline" onsubmit="return confirm('Delete this group?')">
              <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
            </form>
          </div>
          <div class="d-flex justify-content-between align-items-center mt-3">
            <span class="badge bg-secondary"><%= g.member_count %> members</span>
            <div>
              <button class="btn btn-sm btn-outline-info me-1" onclick="copyGroupEmails(<%= g.id %>, '<%= g.name %>')" title="Copy all emails"><i class="bi bi-clipboard"></i> Copy All</button>
              <a href="/groups/<%= g.id %>" class="btn btn-sm btn-primary"><i class="bi bi-eye"></i> Manage</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% }); %>
</div>

<!-- Create Group Modal -->
<div class="modal fade" id="addGroupModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form method="POST" action="/groups/add">
        <div class="modal-header">
          <h5 class="modal-title"><i class="bi bi-people"></i> Create Group</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label fw-semibold">Group Name</label>
            <input type="text" name="name" class="form-control" placeholder="e.g., Marketing Team" required>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Color</label>
            <input type="color" name="color" class="form-control form-control-color" value="#4e73df">
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Description</label>
            <input type="text" name="description" class="form-control" placeholder="Optional description">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Create</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="position-fixed top-0 end-0 p-3" style="z-index:9999">
  <div id="copyToast" class="toast align-items-center text-bg-success" role="alert">
    <div class="d-flex">
      <div class="toast-body" id="toastMsg"><i class="bi bi-check-circle"></i> Copied!</div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
    </div>
  </div>
</div>

<script>
function copyGroupEmails(groupId, groupName) {
  fetch('/groups/' + groupId + '/emails')
    .then(function(r) { return r.json(); })
    .then(function(emails) {
      navigator.clipboard.writeText(emails.join(', ')).then(function() {
        document.getElementById('toastMsg').innerHTML = '<i class="bi bi-check-circle"></i> ' + emails.length + ' emails copied from ' + groupName + '!';
        var t = new bootstrap.Toast(document.getElementById('copyToast'), {delay: 2000});
        t.show();
      });
    });
}
</script>

<%- include('footer') %>
